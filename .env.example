MONGODB_URI=mongodb://localhost:27017/us-estimating-solutions
JWT_SECRET=replace-with-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=replace-with-smtp-password
CONTACT_FROM_EMAIL=no-reply@example.com
CONTACT_RECEIVER_EMAIL=info@example.com

# Public production URL (no trailing slash) used to build absolute URLs in
# robots.txt and sitemap.xml. On Vercel this can be omitted (VERCEL_PROJECT_PRODUCTION_URL
# is used automatically), but setting it explicitly to your real domain is recommended.
NEXT_PUBLIC_SITE_URL=https://usaestimatingsolutions.com

# Admin image uploads on Vercel: create a Blob store in the Vercel project → Storage,
# or paste the token from Project Settings → Environment Variables (BLOB_READ_WRITE_TOKEN).
# Locally: copy the same token into .env.local to test Blob uploads, or omit to use public/uploads/cms.
# BLOB_READ_WRITE_TOKEN=
